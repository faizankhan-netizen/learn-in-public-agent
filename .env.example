# Content Engine — Environment Variables
# Copy this to .env and fill in your values

# ─── LLM Provider ───
# Options: "gemini" (default) or "ollama" (when you have local hardware)
LLM_PROVIDER=gemini

# ─── Gemini API Key(s) ───
# Get your free key at: https://aistudio.google.com/apikey
# Free tier: 1,500 requests/day with Flash models
# Add multiple keys for auto-rotation (if one hits rate limits, the next one kicks in)
GEMINI_API_KEY=your_api_key_here
GEMINI_API_KEY2=optional_second_key
GEMINI_API_KEY3=optional_third_key

# ─── Ollama (future — when MacBook arrives) ───
# OLLAMA_MODEL=qwen3:30b
